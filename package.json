{
  "name": "agentic-tdd",
  "version": "0.1.0-Beta",
  "description": "An npx-executable, agentic TDD pipeline orchestration tool — 8-pass state machine for enterprise software development",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/Digital-Assistant/agentic-tdd-node"
  },
  "bin": {
    "agentic-tdd": "./dist/cli/index.js"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "tsc && npm run copy:agents",
    "copy:agents": "mkdir -p dist/agent && cp -r src/agents/* dist/agent/",
    "build:full": "npm run clean && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "tsc --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build:full"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@opencode-ai/plugin": "1.17.7",
    "commander": "^13.1.0",
    "dotenv": "^16.5.0",
    "execa": "^9.5.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "files": [
    "dist"
  ]
}
